{
  "name": "acme-salary-management",
  "private": true,
  "version": "0.1.0",
  "description": "Salary management web app for ACME's HR Manager persona — Incubyte assessment.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
