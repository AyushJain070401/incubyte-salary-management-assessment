# Copy to apps/web/.env.local and edit if your api is on a different host.
VITE_API_URL=http://localhost:4000

# Supabase Auth — used by the Supabase JS client on the frontend.
# Both values come from your Supabase project's API settings.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
