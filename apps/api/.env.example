# Copy to apps/api/.env and fill in real values.

# HTTP server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins for the SPA
CORS_ORIGINS=http://localhost:5173

# Database. Defaults to the docker-compose Postgres at repo root.
# For production use the Postgres connection string from Supabase
# project settings (Settings -> Database -> Connection string).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/acme_salary

# Supabase auth — used to verify JWTs issued by Supabase Auth on the client.
# Both values come from your Supabase project's API settings.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_JWT_SECRET=replace-with-the-jwt-secret-from-supabase
