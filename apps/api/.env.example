# Copy to apps/api/.env and fill in real values.

# HTTP server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# CORS — comma-separated list of allowed origins for the SPA
CORS_ORIGINS=http://localhost:5173

# Database — Supabase Postgres direct connection string.
# Get it from your Supabase project: Settings -> Database -> Direct connection string.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.qozgupxiovhmfsfuquvn.supabase.co:5432/postgres

# Auth env vars (SUPABASE_URL, SUPABASE_JWT_SECRET) are added when the
# JWT verification middleware lands in a later commit.
