{
  "name": "@acme/api",
  "version": "0.0.0",
  "private": true,
  "description": "ACME salary management — Express + Prisma backend.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "create-hr-user": "tsx scripts/create-hr-user.ts"
  },
  "dependencies": {
    "@acme/shared": "workspace:*",
    "@prisma/client": "^5.20.0",
    "@supabase/supabase-js": "^2.45.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "jose": "^5.9.4",
    "papaparse": "^5.4.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/papaparse": "^5.3.15",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.13.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.20.0",
    "supertest": "^7.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
